# JS / Expo build artifacts -- keep these out of the Python package tree.
node_modules/
.expo/
dist/
web-build/

# Native projects are generated by `expo prebuild` -- regenerate, don't commit.
/android/
/ios/

# Yarn (Berry) internals if used
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
.pnp.*

# Build outputs / logs
*.apk
*.aab
*.keystore
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# Metro / OS
.metro-health-check*
.DS_Store
